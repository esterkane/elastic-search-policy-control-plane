HOST=0.0.0.0
PORT=3000
ELASTICSEARCH_URL=http://localhost:9200
API_URL=http://localhost:3000

# Procedural-learning loop (query logging + policy mining). Default off.
# When false (or unset), query logging is a no-op and mining is inert, so
# existing /plan and /explain behaviour is fully reproducible. Set to "true"
# to enable append-only query logging and the `npm run mine` pipeline.
MEMORY_ENABLED=false
