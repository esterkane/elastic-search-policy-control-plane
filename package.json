{
  "name": "elastic-search-policy-control-plane",
  "version": "0.1.0",
  "private": true,
  "description": "Governed e-commerce search control plane for deterministic Elasticsearch execution plans.",
  "type": "module",
  "engines": {
    "node": ">=24"
  },
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "setup": "docker compose up -d elasticsearch",
    "ingest": "tsx src/scripts/ingest.ts",
    "test": "vitest run",
    "build": "tsc --noEmit"
  },
  "dependencies": {
    "@elastic/elasticsearch": "^8.15.0",
    "fastify": "^4.28.1",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/node": "^22.7.4",
    "tsx": "^4.19.1",
    "typescript": "^5.6.2",
    "vitest": "^2.1.1"
  }
}
