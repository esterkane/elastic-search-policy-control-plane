[
  {
    "id": "p100-without-peanuts",
    "name": "Exclude peanut allergens",
    "priority": 100,
    "match": {
      "phrase": "without peanuts",
      "terms": ["without", "peanuts"]
    },
    "action": {
      "add_exclusion": {
        "field": "allergens",
        "value": "peanuts"
      },
      "remove_phrase": "without peanuts"
    },
    "conflict_strategy": "restrict",
    "explanation": "The query asks to avoid peanuts, so products tagged with peanut allergens are excluded."
  },
  {
    "id": "p90-under-100",
    "name": "Apply explicit price ceiling",
    "priority": 90,
    "match": {
      "phrase": "under 100",
      "terms": ["under", "100"],
      "regex": "\\bunder\\s+100\\b"
    },
    "action": {
      "add_filter": {
        "field": "price",
        "operator": "lte",
        "value": 100
      },
      "remove_phrase": "under 100"
    },
    "conflict_strategy": "restrict",
    "explanation": "The phrase under 100 is interpreted as a hard maximum price filter."
  },
  {
