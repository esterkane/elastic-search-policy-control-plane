      "terms": ["gift", "grandpa"]
    },
    "action": {
      "set_retrieval_strategy": "semantic_stub",
      "remove_phrase": "gift for grandpa"
    },
    "conflict_strategy": "override",
    "explanation": "Gift intent is broad and benefits from semantic routing, represented here as a semantic_stub plan."
  },
  {
